# Copy to `.env` for local Docker Compose overrides.
# These values are safe demo defaults for local development only.

MYSQL_ROOT_PASSWORD=cloudops-root
MYSQL_DATABASE=cloud_ops_monitor
MYSQL_USER=cloudops
MYSQL_PASSWORD=cloudops

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Server runtime examples:
MYSQL_DSN=cloudops:cloudops@tcp(127.0.0.1:3306)/cloud_ops_monitor?charset=utf8mb4&parseTime=True&loc=Local
VICTORIA_METRICS_URL=http://localhost:8428/api/v1/import/prometheus
REDIS_ADDR=localhost:6379
KAFKA_BROKERS=localhost:9092

NOTIFIER_TYPE=noop
WEBHOOK_PROVIDER=feishu
WEBHOOK_URL=
